del_thresh <- -0.6
amp_thresh <- 0.4
min_len_thresh <- 10
calls <- seg_o %>% as_tibble() %>% filter(num.mark >= min_len_thresh) %>% mutate(call = case_when(seg.mean >= amp_thresh ~ "amp", seg.mean <= del_thresh ~ "del", TRUE ~ "neutral")
)
